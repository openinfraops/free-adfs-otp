{
  "ConnectionStrings": {
    "OtpSql": "Server=localhost;Database=FreeAdfsOtp;Integrated Security=true;TrustServerCertificate=true;"
  },
  "SecretProtection": {
    "MasterKey": "REPLACE_WITH_32BYTE_BASE64_KEY",
    "MasterKeyDpapiFilePath": ""
  },
  "LocalCache": {
    "Enabled": false,
    "AllowSqlFallbackForValidation": true,
    "DatabasePath": "cache/freeadfsotp-node-cache.db",
    "NodeKeySalt": "",
    "InitialFullSyncEnabled": true,
    "PeriodicSyncEnabled": true,
    "PeriodicSyncIntervalSeconds": 30
  },
  "SqlResilience": {
    "DegradedModeWindowSeconds": 30,
    "ProbeIntervalSeconds": 5
  },
  "Otp": {
    "TotpDigits": 6,
    "TotpStepSeconds": 30,
    "TotpAllowedSkewSteps": 1
  },
  "Lockout": {
    "MaxFailedAttempts": 5,
    "FailedWindowMinutes": 10,
    "LockoutMinutes": 15
  },
  "Enrollment": {
    "PendingTtlMinutes": 10,
    "CleanupIntervalMinutes": 5
  },
  "AdminAuth": {
    "ApiKey": "REPLACE_WITH_LONG_RANDOM_ADMIN_API_KEY",
    "ApiKeyDpapiFilePath": ""
  },
  "RateLimiting": {
    "OtpValidatePerIpLimit": 30,
    "OtpValidatePerIpWindowSeconds": 60,
    "OtpValidatePerUpnLimit": 10,
    "OtpValidatePerUpnWindowSeconds": 60,
    "EnrollmentStartPerIpLimit": 10,
    "EnrollmentStartPerIpWindowSeconds": 300,
    "EnrollmentVerifyPerIpLimit": 20,
    "EnrollmentVerifyPerIpWindowSeconds": 300,
    "AdminPerIpLimit": 30,
    "AdminPerIpWindowSeconds": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
